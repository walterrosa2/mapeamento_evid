# Variáveis de Ambiente — Template
# Copie este arquivo para .env e preencha com suas credenciais

# =====================================================
# API Key do Google Gemini (obrigatório)
# =====================================================
GOOGLE_API_KEY=sua_chave_aqui

# =====================================================
# SMTP — Envio de email ao final do processamento
# Opcional: se não configurado, o envio é ignorado
# =====================================================

# Servidor SMTP (ex: smtp.gmail.com, smtp.office365.com)
SMTP_HOST=smtp.gmail.com

# Porta SMTP (587 para TLS/STARTTLS, 465 para SSL)
SMTP_PORT=587

# Usuário remetente (seu email)
SMTP_USER=seu@gmail.com

# Senha de app (Gmail: https://myaccount.google.com/apppasswords)
SMTP_PASS=sua_senha_de_app

# Ativar STARTTLS (true/false)
SMTP_TLS=true
